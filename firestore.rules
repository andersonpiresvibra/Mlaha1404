rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: flights
    // Fields: flightNumber (string), airline (string), status (string), etc.
    //
    // Collection: operators
    // Fields: warName (string), status (string), etc.
    //
    // Collection: finalized_flights
    // Fields: flightId (string), flightData (map), finalizedAt (timestamp)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "anderson.hpires@gmail.com" && request.auth.token.email_verified == true
        );
    }

    function isValidFlight(data) {
      return data.flightNumber is string && data.flightNumber.size() > 0 && data.flightNumber.size() <= 50 &&
             data.airline is string && data.airline.size() > 0 && data.airline.size() <= 100 &&
             data.status in ['CHEGADA', 'FILA', 'DESIGNADO', 'AGUARDANDO', 'ABASTECENDO', 'FINALIZADO', 'CANCELADO'] &&
             (!('registration' in data) || (data.registration is string && data.registration.size() <= 50)) &&
             (!('model' in data) || (data.model is string && data.model.size() <= 100)) &&
             (!('origin' in data) || (data.origin is string && data.origin.size() <= 50)) &&
             (!('destination' in data) || (data.destination is string && data.destination.size() <= 50)) &&
             (!('observations' in data) || (data.observations is string && data.observations.size() <= 2000)) &&
             (!('delayJustification' in data) || (data.delayJustification is string && data.delayJustification.size() <= 1000));
    }

    function isValidOperator(data) {
      return data.warName is string && data.warName.size() > 0 && data.warName.size() < 50 &&
             data.status in ['DISPONÍVEL', 'OCUPADO', 'INTERVALO', 'DESCONECTADO', 'ENCHIMENTO', 'DESIGNADO'] &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 100)) &&
             (!('assignedVehicle' in data) || (data.assignedVehicle is string && data.assignedVehicle.size() < 20));
    }

    function isValidFleet(data) {
      return data.fleetNumber is string && data.fleetNumber.matches('^\\d{4}$') &&
             data.type in ['SRV', 'CTA'] &&
             (!('brand' in data) || (data.brand is string && data.brand.size() < 50));
    }

    function isValidMalhaBaseEntry(data) {
      return (!('comp' in data) || (data.comp is string && data.comp.size() <= 100)) &&
             (!('prefixo' in data) || (data.prefixo is string && data.prefixo.size() <= 50)) &&
             (!('modelo' in data) || (data.modelo is string && data.modelo.size() <= 100)) &&
             (!('vCheg' in data) || (data.vCheg is string && data.vCheg.size() <= 50)) &&
             (!('eta' in data) || (data.eta is string && data.eta.size() <= 50)) &&
             (!('vSaida' in data) || (data.vSaida is string && data.vSaida.size() <= 50)) &&
             (!('icao' in data) || (data.icao is string && data.icao.size() <= 50)) &&
             (!('cid' in data) || (data.cid is string && data.cid.size() <= 50)) &&
             (!('pos' in data) || (data.pos is string && data.pos.size() <= 50)) &&
             (!('etd' in data) || (data.etd is string && data.etd.size() <= 50));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /flights/{flightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFlight(request.resource.data);
      allow update: if isAuthenticated() && isValidFlight(request.resource.data);
      allow delete: if isAdmin();
    }

    match /malha_base/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMalhaBaseEntry(request.resource.data);
      allow update: if isAuthenticated() && isValidMalhaBaseEntry(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /operators/{operatorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidOperator(request.resource.data);
      allow update: if isAuthenticated() && isValidOperator(request.resource.data);
      allow delete: if isAdmin();
    }

    match /finalized_flights/{flightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /airlines/{airlineId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /aircraft_database/{aircraftId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /fleet/{fleetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFleet(request.resource.data);
      allow update, delete: if isAdmin() && isValidFleet(request.resource.data);
    }
  }
}
